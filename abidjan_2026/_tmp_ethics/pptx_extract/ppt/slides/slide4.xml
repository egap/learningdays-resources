00B050"/></a:solidFill></a:rPr><a:t> </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2400" b="1" i="1" dirty="0" err="1"><a:solidFill><a:srgbClr val="00B050"/></a:solidFill></a:rPr><a:t>when</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2400" b="1" i="1" dirty="0"><a:solidFill><a:srgbClr val="00B050"/></a:solidFill></a:rPr><a:t> </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2400" b="1" i="1" dirty="0" err="1"><a:solidFill><a:srgbClr val="00B050"/></a:solidFill></a:rPr><a:t>designing</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2400" b="1" i="1" dirty="0"><a:solidFill><a:srgbClr val="00B050"/></a:solidFill></a:rPr><a:t> </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2400" b="1" i="1" dirty="0" err="1"><a:solidFill><a:srgbClr val="00B050"/></a:solidFill></a:rPr><a:t>experimental</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2400" b="1" i="1" dirty="0"><a:solidFill><a:srgbClr val="00B050"/></a:solidFill></a:rPr><a:t> </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2400" b="1" i="1" dirty="0" err="1"><a:solidFill><a:srgbClr val="00B050"/></a:solidFill></a:rPr><a:t>research</a:t></a:r><a:endParaRPr lang="fr-FR" sz="2400" b="1" i="1" dirty="0"><a:solidFill><a:srgbClr val="00B050"/></a:solidFill></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="5" name="Espace réservé du contenu 4"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{E6C8056A-0DBE-2549-2286-AD0549B7BAB1}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr><a:spLocks noGrp="1"/></p:cNvSpPr><p:nvPr><p:ph sz="half" idx="1"/></p:nvPr></p:nvSpPr><p:spPr><a:xfrm><a:off x="420130" y="1123406"/><a:ext cx="5599670" cy="5549243"/></a:xfrm></p:spPr><p:txBody><a:bodyPr><a:noAutofit/></a:bodyPr><a:lstStyle/><a:p><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t>La recherche sur des sujets humains nécessite généralement de minimiser les risques pour les participants et de maximiser les avantages pour la société (</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t>principe de bienfaisance</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t>).</a:t></a:r></a:p><a:p><a:endParaRPr lang="fr-FR" sz="2000" dirty="0"><a:solidFill><a:srgbClr val="000000"/></a:solidFill></a:endParaRPr></a:p><a:p><a:r><a:rPr lang="fr-CI" sz="2000" dirty="0"><a:solidFill><a:srgbClr val="000000"/></a:solidFill></a:rPr><a:t>La </a:t></a:r><a:r><a:rPr lang="fr-CI" sz="2000" dirty="0"/><a:t>recherche</a:t></a:r><a:r><a:rPr lang="fr-CI" sz="2000" dirty="0"><a:solidFill><a:srgbClr val="000000"/></a:solidFill></a:rPr><a:t> ne doit pas nuire</a:t></a:r></a:p><a:p><a:pPr marL="457200" lvl="1" indent="0"><a:buNone/></a:pPr><a:endParaRPr lang="fr-FR" sz="2000" dirty="0"/></a:p><a:p><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t>Une intervention récente dans une école d’un village pauvre au Niger (Tahoua) confronté souvent à la famine. L’intervention à consister à mettre en place une cantine scolaire qui offre un déjeuner non pas à tous les enfants pauvres de l’école, mais à la moitié d’entre eux. L’objectif de l’intervention était de savoir si la cantine scolaire allait améliorer leurs résultats scolaires. </a:t></a:r></a:p><a:p><a:pPr lvl="1"/><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t>Est-ce que cette intervention est éthique ?</a:t></a:r></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="6" name="Espace réservé du contenu 5"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{477BDAFE-24B9-9665-0D5F-59AC57EC1C2F}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr><a:spLocks noGrp="1"/></p:cNvSpPr><p:nvPr><p:ph sz="half" idx="2"/></p:nvPr></p:nvSpPr><p:spPr><a:xfrm><a:off x="6172199" y="1123406"/><a:ext cx="5599669" cy="5549243"/></a:xfrm></p:spPr><p:txBody><a:bodyPr><a:normAutofit/></a:bodyPr><a:lstStyle/><a:p><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"/><a:t>Research</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t> </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"/><a:t>with</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t> </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"/><a:t>human</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t> </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"/><a:t>subjects</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t> </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"/><a:t>generally</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t> </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"/><a:t>requires</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t> </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"/><a:t>minimizing</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t> </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"/><a:t>risks</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t> to participants and </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"/><a:t>maximizing</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t> </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"/><a:t>benefits</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t> to society (</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t>Principle</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t> of </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t>beneficence</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t>).  </a:t></a:r></a:p><a:p><a:endParaRPr lang="fr-FR" sz="2000" dirty="0"/></a:p><a:p><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"/><a:t>Research</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t> </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"/><a:t>should</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t> do no (</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"/><a:t>known</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0"/><a:t>) </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="2000" dirty="0" err="1"/><a:t>harm</a:t></a:r><a:endParaRPr lang="fr-FR" sz="2000" dirty="0"/></a:p><a:p><a:pPr marL="0" indent="0"><a:buNone/></a:pPr><a:endParaRPr lang="fr-FR" sz="2000" dirty="0"/></a:p><a:p><a:r><a:rPr lang="en-US" sz="2000" noProof="0" dirty="0"/><a:t>A recent </a:t></a:r><a:r><a:rPr lang="en-US" sz="2000" dirty="0"/><a:t>intervention took place in a school in a poor village in Niger (Tahoua), which frequently </a:t></a:r><a:r><a:rPr lang="en-US" sz="2000" noProof="0" dirty="0"/><a:t>faces famine. The intervention consisted of setting up a school canteen that provides lunch not to all the poor children in the school, but to half of them. The objective of the intervention was </a:t></a:r><a:r><a:rPr lang="en-US" sz="2000" dirty="0"/><a:t>to determine if the school canteen would improve students' </a:t></a:r><a:r><a:rPr lang="en-US" sz="2000" noProof="0" dirty="0"/><a:t>academic performance.</a:t></a:r></a:p><a:p><a:pPr lvl="1"/><a:r><a:rPr lang="en-US" sz="2000" noProof="0" dirty="0"/><a:t>Is this ethical?  </a:t></a:r><a:endParaRPr lang="fr-FR" sz="2000" dirty="0"/></a:p></p:txBody></p:sp></p:spTree><p:extLst><p:ext uri="{BB962C8B-B14F-4D97-AF65-F5344CB8AC3E}"><p14:creationId xmlns:p14="http://schemas.microsoft.com/office/powerpoint/2010/main" val="3673241966"/></p:ext></p:extLst></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr></p:sld>